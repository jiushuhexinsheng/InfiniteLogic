# ============================================================================
# InfiniteLogic 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================================

# --- LLM 配置 (必填) ---
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=120

# LLM 重试与熔断
LLM_RETRY_MAX=3
LLM_RETRY_BACKOFF_BASE=1.0
LLM_RETRY_BACKOFF_MAX=30.0
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_COOLDOWN=30

# DeepSeek 思考模式 (仅 V4 模型)
LLM_THINKING_ENABLED=false
LLM_REASONING_EFFORT=high
SHOW_REASONING=true

# --- Agent 配置 ---
AGENT_RECURSION_LIMIT=50
AGENT_MAX_HISTORY_MESSAGES=80

# 历史压缩：超过 N 条消息时触发 LLM 摘要
AGENT_SUMMARIZE_THRESHOLD=50
AGENT_SUMMARIZE_KEEP_RECENT=10

# 工具并行化：无副作用工具 asyncio.gather 并行执行
AGENT_PARALLEL_TOOLS=true

# --- LLM 缓存 ---
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=1000

# --- 会话存储 ---
SESSION_DB_PATH=./sessions.db
# WAL 模式：并发读不阻塞写 (推荐开启)
SESSION_WAL_ENABLED=true
SESSION_MESSAGE_PAGE_SIZE=100
SESSION_TTL_DAYS=30

# --- 工作区 (文件工具沙箱) ---
WORKSPACE_DIR=./workspace

# --- Python 执行沙箱 ---
# subprocess: 仅隔离崩溃 (默认) | docker: 容器隔离 | disabled: 禁用
SANDBOX_MODE=subprocess
SANDBOX_DOCKER_IMAGE=infinite-logic-sandbox
SANDBOX_MEMORY_LIMIT=128M
SANDBOX_CPU_LIMIT=0.5

# --- RAG 配置 ---
RAG_DOCS_DIR=./docs
RAG_PERSIST_DIR=./qdrant_db
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K_RETRIEVAL=20
RAG_TOP_K_RERANK=4
RAG_HYBRID_ENABLED=true
RAG_RERANKER_ENABLED=true
RAG_RERANKER_MODEL=BAAI/bge-reranker-base
# 自动入库：文件监听 (需启动 Web Server)
RAG_AUTO_INGEST=false
RAG_HEALTH_CHECK_ENABLED=true

# --- Web 鉴权 ---
# 逗号分隔的 API Key；留空则拒绝所有请求（auth_enabled=true 时）
API_KEYS=
RATE_LIMIT_PER_MINUTE=20
AUTH_ENABLED=true
AUTH_SKIP_METRICS=true

# --- 追踪 ---
TRACING_ENABLED=true

# --- 日志 ---
LOG_LEVEL=INFO
LOG_TO_STDERR=false
